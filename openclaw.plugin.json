{
  "id": "colony",
  "name": "Colony",
  "description": "Colony intelligence sidecar — graph memory, context assembly, safety pipeline, autonomy loop. Mounts into OpenClaw as context engine and memory capability provider.",
  "version": "0.6.25",
  "contracts": {
    "contextEngine": true,
    "memory": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable the Colony plugin"
      },
      "sidecarUrl": {
        "type": "string",
        "default": "http://127.0.0.1:7777",
        "description": "URL of the Colony sidecar"
      },
      "apiKey": {
        "type": "string",
        "description": "API key for Colony sidecar authentication"
      },
      "hostId": {
        "type": "string",
        "default": "openclaw",
        "description": "Host identifier for Colony"
      },
      "ownContextEngine": {
        "type": "boolean",
        "default": true,
        "description": "Colony provides its own context engine implementation"
      },
      "ownMemoryCapability": {
        "type": "boolean",
        "default": true,
        "description": "Colony provides its own memory capability implementation"
      }
    },
    "required": ["sidecarUrl", "apiKey"]
  },
  "uiHints": {
    "sidecarUrl": {
      "label": "Sidecar URL",
      "placeholder": "http://127.0.0.1:7777"
    },
    "apiKey": {
      "label": "API Key",
      "sensitive": true
    }
  }
}
