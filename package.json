{
  "name": "@aevonix/colonyai",
  "version": "0.6.8",
  "description": "Colony's intelligence sidecar — graph memory, autonomy loop, context assembly, safety pipeline — mountable into OpenClaw, Hermes, and other agent harnesses via the /v1/host API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate-types": "cd sidecar && PYTHONPATH=. python3 export_openapi.py && cd .. && openapi-typescript openapi.json -o src/types-generated.ts",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "colony",
    "sidecar",
    "openclaw",
    "hermes",
    "agent",
    "memory",
    "intelligence",
    "context-engine",
    "safety"
  ],
  "author": "Aevonix <https://github.com/aevonix>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aevonix/colony.git"
  },
  "homepage": "https://github.com/aevonix/colony#readme",
  "bugs": {
    "url": "https://github.com/aevonix/colony/issues"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "peerDependencies": {
    "openclaw": "^2026.4.21"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "openapi-typescript": "^7.13.0",
    "openclaw": "^2026.4.21",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
