# Colony Sidecar - Example Configuration
# Copy to ~/.colony/.env and fill in your values.
#
# NOTE: Colony does NOT need LLM keys here. The host (Hermes, an MCP client,
# or anything speaking the REST API) provides LLM credentials at runtime via
# POST /v1/host/configure, and they are persisted in the state dir.
#
# `colony init` writes most of this for you. `colony doctor` validates it.

# =============================================================================
# CORE
# =============================================================================

# Bind address — use 0.0.0.0 for remote agent connections
# COLONY_SIDECAR_HOST=0.0.0.0
COLONY_SIDECAR_HOST=127.0.0.1
COLONY_SIDECAR_PORT=7777

# Bearer token required by the sidecar API (colony init generates one)
COLONY_API_KEY=

# Where stores and config live (default ~/.colony)
# COLONY_STATE_DIR=~/.colony

# Contacts database filename, relative to the state dir
COLONY_CONTACTS_DB=colony-contacts.db

# Graph store (Neo4j 5.x over Bolt)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# The agent's authoritative timezone (temporal awareness)
# COLONY_AGENT_TIMEZONE=UTC
# Owner-local timezone for quiet hours and autonomy scheduling
# COLONY_TIMEZONE=UTC

LOG_LEVEL=info

# =============================================================================
# OWNER & APPROVAL
# =============================================================================

# The owner's contact id. Used by the approval gate, owner-preference
# learning, trust-engine notifications, and the delivery path.
# COLONY_OWNER_CONTACT_ID=

# Approval policy for gated actions: strict (default) or graduated.
# COLONY_APPROVAL_POLICY=strict

# =============================================================================
# AUTONOMY PRESET — the one knob
# =============================================================================
# COLONY_AUTONOMY_PRESET supplies DEFAULTS for all fourteen autonomy flags at
# once. An explicitly set env var always wins over the preset.
#
#   passive     — observe and remember only; nothing thinks, acts, or writes.
#   calibration — everything runs in shadow/dry_run and EARNS autonomy through
#                 the trust engine (the recommended starting point; the wizard
#                 default). Capability classes auto-graduate from their real
#                 track record, notifying the owner.
#   autonomous  — subsystems run live, still bounded by directive boundaries,
#                 approval tiering, the immutable floor, and trust gating.
#
# The sandbox never goes live from a preset ("autonomous" caps it at dry_run);
# live code execution is always an explicit per-deployment decision.
#
# GET /v1/host/autonomy/posture returns the RESOLVED posture of the running
# process.
# COLONY_AUTONOMY_PRESET=calibration

# --- Per-subsystem overrides (each one beats the preset when set) -----------

# In-process initiative executor (reasons about initiatives with the agent's
# own LLM + tools): true / false
# COLONY_EXECUTOR_ENABLED=true
# COLONY_EXECUTOR_MODEL_TIER=small          # small / medium / large
# COLONY_EXECUTOR_TYPES=                    # csv of initiative types to handle
# COLONY_EXECUTOR_CYCLE_SECS=30
# COLONY_EXECUTOR_MAX_PER_CYCLE=5
# COLONY_EXECUTOR_MAX_TOOL_ITERS=           # max tool rounds per initiative

# Background cognition and per-turn introspection: true / false
# COLONY_COGNITION_ENABLED=true
# COLONY_INTROSPECT_ENABLED=true

# Self-directed thinking (proposals from idle reflection): off / shadow / live
# COLONY_THINKING_MODE=shadow
# COLONY_THINKING_INTERVAL_SECS=3600
# COLONY_THINKING_MAX_INITIATIVES=3

# Goal persistence / multi-step project pursuit: off / shadow / live
# COLONY_PROJECTS_MODE=shadow

# Belief maintenance (contradiction detection, resolution, decay):
# off / shadow / live
# COLONY_BELIEFS_MODE=shadow

# World-model population from conversation: off / shadow / live
# COLONY_WORLD_POPULATE_MODE=shadow
# LLM-assisted world extraction: off / shadow / live
# COLONY_WORLD_LLM_EXTRACT=shadow

# Skill distillation (compounding procedure memory): off / shadow / live
# COLONY_SKILLS_DISTILL=shadow

# Escalation mining (spot correction/consultation turns for
# self-improvement): off / shadow / live
# COLONY_ESCALATION_MINING=shadow
# Training-corpus exporter (POST /v1/host/mining/corpus/export; writes JSONL
# under the state dir only): true / false
# COLONY_CORPUS_EXPORT_ENABLED=true

# Directed action via delegation: off / dry_run / live
# COLONY_DIRECTED_MODE=dry_run
# COLONY_DIRECTED_TASK_URL=

# =============================================================================
# CONNECTORS (senses) — read-only pull connectors
# =============================================================================
# COLONY_CONNECTORS_MODE: off / shadow / live. In shadow, connectors poll and
# LOG what they would ingest, writing nothing. Each connector is then enabled
# and configured individually via COLONY_CONNECTOR_<NAME>_<KEY>.
# COLONY_CONNECTORS_MODE=shadow

# IMAP email (read-only; never sends)
# COLONY_CONNECTOR_IMAP_ENABLED=true
# COLONY_CONNECTOR_IMAP_HOST=imap.example.com
# COLONY_CONNECTOR_IMAP_PORT=993
# COLONY_CONNECTOR_IMAP_USER=
# COLONY_CONNECTOR_IMAP_PASSWORD=
# COLONY_CONNECTOR_IMAP_MAILBOX=INBOX
# COLONY_CONNECTOR_IMAP_MAX=20
# COLONY_CONNECTOR_IMAP_POLL_SECS=900

# Calendar via ICS URL (read-only)
# COLONY_CONNECTOR_CALENDAR_ENABLED=true
# COLONY_CONNECTOR_CALENDAR_ICS_URL=https://example.com/calendar.ics
# COLONY_CONNECTOR_CALENDAR_USER=
# COLONY_CONNECTOR_CALENDAR_PASSWORD=
# COLONY_CONNECTOR_CALENDAR_POLL_SECS=1800

# Filesystem documents (watch a folder)
# COLONY_CONNECTOR_FS_ENABLED=true
# COLONY_CONNECTOR_FS_PATH=~/Documents/inbox
# COLONY_CONNECTOR_FS_EXTENSIONS=txt,md,pdf,docx
# COLONY_CONNECTOR_FS_POLL_SECS=600

# Generic webhook pull (poll a JSON endpoint)
# COLONY_CONNECTOR_WEBHOOK_ENABLED=true
# COLONY_CONNECTOR_WEBHOOK_URL=
# COLONY_CONNECTOR_WEBHOOK_AUTH_HEADER=
# COLONY_CONNECTOR_WEBHOOK_AUTH_VALUE=
# COLONY_CONNECTOR_WEBHOOK_FIELD_MAP={}
# COLONY_CONNECTOR_WEBHOOK_POLL_SECS=3600

# =============================================================================
# WORKERS — distributed job execution (server-governed)
# =============================================================================
# COLONY_WORKERS_MODE gates the server-side WorkerGovernor: off / shadow /
# live. Workers are untrusted; claims and reports are re-verified server-side.
# COLONY_WORKERS_MODE=shadow

# The `colony-worker` daemon (systemd/launchd templates ship under
# sidecar/colony_sidecar/workers/deploy/):
# COLONY_WORKER_NODE_ID=                    # default <agent>-worker
# COLONY_WORKER_CAPABILITIES=research,analyst,read
# COLONY_WORKER_JOB_TYPES=research
# COLONY_WORKER_MAX_JOBS=1
# COLONY_WORKER_POLL_SECS=30
# COLONY_WORKER_LLM_BASE_URL=               # default OPENAI_BASE_URL
# COLONY_WORKER_LLM_MODEL=gpt-4o-mini
# COLONY_WORKER_LLM_API_KEY=                # default OPENAI_API_KEY

# =============================================================================
# SANDBOX — gated Docker exploration sandbox
# =============================================================================
# off / dry_run / live. Live runs scripts in a locked-down container
# (--network none, no credentials, read-only rootfs, capped resources) behind
# boundary checks and approval tiering. Never enabled live by a preset.
# COLONY_SANDBOX_MODE=off
# COLONY_SANDBOX_IMAGE=python:3.12-slim
# COLONY_SANDBOX_CPUS=1.0
# COLONY_SANDBOX_MEMORY=512m
# COLONY_SANDBOX_TIMEOUT=30
# COLONY_SANDBOX_PIDS=128
# COLONY_SANDBOX_EGRESS=none                # keep "none" unless you know why
# COLONY_SANDBOX_MAX_ARTIFACT_BYTES=1048576

# =============================================================================
# TRUST ENGINE — earned, graduated autonomy
# =============================================================================
# Per action class: shadow -> ask_first -> act_first, driven by the real
# journaled track record. Defaults are sane; override with care.
# COLONY_TRUST_AUTOGRADUATE=true            # false = stages never auto-promote
# COLONY_TRUST_ACT_THRESHOLD=0.8            # confidence needed to act
# COLONY_TRUST_ASK_MIN_N=3                  # clean shadow runs to reach ask_first
# COLONY_TRUST_ACT_MIN_N=5                  # real outcomes to reach act_first
# COLONY_TRUST_BREAKER_FAILURES=3           # failures in window -> demote
# COLONY_TRUST_BREAKER_WINDOW_HOURS=24
# Ceiling of the adaptive daily proactive-delivery cap
# COLONY_TRUST_DELIVERY_CAP_MAX=6

# =============================================================================
# DELIVERY & HOME CHANNEL
# =============================================================================
# Where proactive initiatives are delivered. Set at least one home channel
# (<PLATFORM>_HOME_CHANNEL) or initiatives will queue but never deliver:
# TELEGRAM_HOME_CHANNEL=
# WHATSAPP_HOME_CHANNEL=
# DISCORD_HOME_CHANNEL=
# SLACK_HOME_CHANNEL=
# SIGNAL_HOME_CHANNEL=

# Transport for reach-out delivery:
#   hermes_webhook (default) — POST the structured initiative to a composing
#                              agent's webhook, which writes the final message
#   gateway                  — POST sanitised text to a message gateway that
#                              speaks the flat {platform, chat_id, message}
#                              contract
# COLONY_DELIVERY_TRANSPORT=hermes_webhook

# Built-in agent bridge (forwards initiatives/jobs to a host webhook; the
# service auto-starts at boot when this is set):
# COLONY_BRIDGE_WEBHOOK_URL=

# =============================================================================
# MODELS & SEARCH
# =============================================================================

# HuggingFace token for faster model downloads (optional)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxx

# Embedding + reranker — auto-detected by colony init.
# Override here for API embeddings or a custom model.
COLONY_EMBED_PROVIDER=
COLONY_EMBED_MODEL=
COLONY_EMBED_DIMS=
COLONY_RERANKER_MODEL=

# Multimodal embeddings (enable with `colony activate-multimodal`)
COLONY_MULTIMODAL=false

# Web search for the research pipeline. Unset = keyless DuckDuckGo fallback.
# COLONY_SEARCH_PROVIDER=tavily             # tavily / brave / serpapi
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# SERPAPI_KEY=

# =============================================================================
# INITIATIVE ENGINE THRESHOLDS
# =============================================================================
# How sensitive proactive initiative generation is.

# Days of no contact before generating a relationship initiative (default: 7)
# COLONY_INITIATIVE_CONTACT_NEGLECT_DAYS=7

# Days a goal must be blocked before generating a follow-up (default: 1)
# COLONY_INITIATIVE_GOAL_BLOCK_DAYS=1

# Health score threshold — below this generates an alert (default: 70.0)
# COLONY_INITIATIVE_HEALTH_THRESHOLD=70.0

# Minimum calendar gap (hours) to count as opportunity (default: 2.0)
# COLONY_INITIATIVE_GAP_THRESHOLD=2.0

# Research task age (days) before generating an initiative (default: 1)
# COLONY_INITIATIVE_RESEARCH_AGE_DAYS=1

# Signal accumulation threshold before generating an initiative (default: 10)
# COLONY_INITIATIVE_SIGNAL_THRESHOLD=10

# ── Relationship intelligence (docs/RELATIONSHIPS.md) ────────────────────────
# Unknown senders become shadow contacts so history accrues from first
# contact (default: true)
# COLONY_IDENTITY_SHADOW_CONTACTS=true

# Channel prefixes whose senderless turns attribute to the machine sentinel
# instead of a person (default: cron,api,internal)
# COLONY_IDENTITY_MACHINE_CHANNELS=cron,api,internal

# New interactions before a contact is (re)profiled (default: 5)
# COLONY_RELATIONSHIP_PROFILE_MIN_INTERACTIONS=5

# Relationship profiling phase cadence in seconds (default: 21600)
# COLONY_RELATIONSHIP_PROFILE_REFRESH_SECS=21600

# Include approach guidance (best channel/time, engagement style) in
# relationship briefs (default: true)
# COLONY_APPROACH_GUIDANCE=true

# Extra keyword-match common terms the boundary matcher must never treat as
# a lone match signal (csv; the product and agent names are always included)
# COLONY_MATCH_COMMON_TERMS=

# --- Selfhood benchmark (Mind M0a) ---
# Weekly self-improvement metrics derived from journals (never self-reported).
# COLONY_BENCHMARK_ENABLED=true
# Deliver the weekly scorecard to the owner as a proposal.
# COLONY_BENCHMARK_REPORT=true
# Recall probes per weekly compute (high-confidence facts re-queried).
# COLONY_BENCHMARK_PROBES=8

# --- Experiment framework (Mind M0b) ---
# Bounded, guarded self-changes (adaptive-param variants judged against a
# benchmark metric, auto-revert on regression).
# COLONY_EXPERIMENTS_ENABLED=true
# Concurrent running experiments cap.
# COLONY_EXPERIMENTS_MAX_RUNNING=2

# --- Toolsmith (Mind M1): self-built, sandbox-verified tools ---
# off | shadow | live. shadow: mine + draft + verify + accumulate shadow
# runs, graduation needs owner approval. live: same, but auto-graduate once
# the toolsmith trust domain reaches act_first. Requires the Docker sandbox
# (COLONY_SANDBOX_MODE=live) to verify and run tools.
# COLONY_TOOLSMITH=off
# Journal occurrences before a procedure becomes a tool candidate.
# COLONY_TOOLSMITH_MIN_OCCURRENCES=4
# Clean shadow runs before a tool is graduation-eligible.
# COLONY_TOOLSMITH_SHADOW_MIN=5
# Journal domains never mined for tools.
# COLONY_TOOLSMITH_EXCLUDE_DOMAINS=meta_learning,sandbox,toolsmith
